# Docker image'a dahil edilmeyecek dosyalar
#
# Amac: build context'i kucult, gelistirme/release artifact'lerini
# container icinde tutma, hassas dosyalari isaretle.

# Release artifact'leri (build sonucu uretilenler)
*.exe
*.nsi
*.ico
*.zip
xampp-*.exe
AnimeTracker*.exe

# Belge ve metin dosyalari (kullaniciya gerek yok)
*.md
*.txt
!files/version.txt

# Test ve gelistirme dosyalari
session_test.php
csrf_test.php
docker_test/

# Version control
.git
.gitignore
.gitattributes

# Docker kontrol dosyalari (image'in disinda kullanilir)
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore

# Ortam degiskenleri (HASSAS - .env asla image'a girmemeli)
.env
.env.local
.env.*.local

# Sir tasiyan PHP dosyalari (HASSAS - savunma ikinci kat).
# Normalde admin tarafi files/ disinda tutulur ve config.php
# docker-entrypoint.sh tarafindan ortam degiskenlerinden uretilir;
# bu blok yanlislikla files/'a sir dusmesine karsi ek guvencedir.
# **/ on eki gerekli: uygulama files/'tan kopyalanir, kok eslesme yetmez.
# *_example.php sablonlari ESLENMEZ (gercek sir tasimaz, image'da kalir).
**/config.php
**/admin_secret.php
**/anime_api_config.php
**/admin_sync.php
**/admin_push_config.php
