# Anime Tracker - Ornek Ortam Degiskenleri
#
# ===========================================================
# KULLANIM:
# Bu dosyayi ".env" olarak kopyalayin ve degerleri DEGISTIRIN.
#   cp .env.example .env       (Linux/macOS)
#   copy .env.example .env     (Windows)
# Sonra .env dosyasini acip ozellikle SIFRELERI guncelleyin.
# ===========================================================
#
# GUVENLIK NOTU:
# .env dosyasi .gitignore'da - git'e ASLA gitmemeli. Sifreleri
# uzun ve rastgele yapin (16+ karakter, harf+rakam+sembol).
# Onerilen: parola yoneticisi (Bitwarden, 1Password, KeePass)
# ile rastgele sifre uretin.

# --- Veritabani sifreleri (ZORUNLU DEGISTIRIN) ---

# MariaDB root sifresi - sadece DB yonetimi icin, normal kullanimda
# gerekmez. Yine de tahmin edilemez bir deger olmali.
DB_ROOT_PASS=change_me_to_a_long_random_root_password

# Anime Tracker'in DB'ye baglandigi kullanici sifresi.
# Bu sifre config.php'ye yazilir (container icinde).
DB_PASS=change_me_to_a_different_long_random_password

# --- Veritabani isimleri (gerekirse degistirin, opsiyonel) ---

# DB adi (varsayilan: anime_tracker)
DB_NAME=anime_tracker

# DB kullanici adi (varsayilan: anime_user)
DB_USER=anime_user

# --- Port yapilandirmasi (opsiyonel) ---

# Host port - tarayicidan hangi porttan erisileceginizi belirler.
# Varsayilan: 8080. XAMPP veya baska sistem 8080 kullaniyorsa
# baska bir port (or. 8090) secin.
APP_PORT=8080
