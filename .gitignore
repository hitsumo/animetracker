# Anime Tracker - .gitignore

# Kullanici'ya ozel konfig - asla commit etme (DB sifreleri icerir)
files/config.php

# Admin tool dosyalari - hassas veri iceren dosyalar
# admin_sync.php: hedef sunucu URL'i var, example versiyonu repo'da
# admin_secret.php: HMAC anahtari, example versiyonu repo'da
# NOT: admin.php ve admin_pending.php hassas veri icermez,
#      direkt repo'da yer alir (example gereksiz).
admin_sync.php
admin_secret.php
AnimeTracker-v0.5/files/admin_sync.php
AnimeTracker-v0.5/files/admin_secret.php

# Sunucu tarafindaki config dosyalari (sadece server'da olmali)
# Example versiyonlari repo'da yer alir.
anime_api_config.php
admin_push_config.php

# Kullanici yukledigi kapak gorselleri (uploads/.htaccess haric)
files/uploads/*
!files/uploads/.htaccess

# Runtime cache ve gecici dosyalar
files/temp/
files/catalog_cache.json
files/catalog_cache.json.tmp

# Build ciktilari
AnimeTracker.exe
*.zip

# XAMPP installer (150 MB - repoya koyma, release'de dagit)
xampp-*.exe

# Gelistirme artiklari
dizin_listesi.txt
dizin_yapisi.txt
*.JPG
*.jpg
*.png
!files/img/*.jpg
!files/img/*.png
!anime-tracker-icon.ico

# Gelistirme dokumantasyonu (kisisel notlar, projeyle paylasma)
PROJE_DURUMU.md

# Test dosyalari
session_test.php
csrf_test.php
test.php

# Editor / OS artiklari
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store
desktop.ini

# Log dosyalari
*.log
error_log

# Yedekler
*.bak
*.backup
*_backup.sql


# Anime Tracker - .gitignore'a eklenmesi onerilen satirlar
# (Mevcut .gitignore zaten varsa, asagidaki satirlarin orada
# bulunup bulunmadigini kontrol et. Yoksa ekle.)

# Docker - ortam degiskenleri (gercek sifreler)
.env
.env.local
.env.*.local

# NOT: .env.example commit edilir (ornek dosya, gercek sifre icermez)
# Sadece ".env" ve "*.local" varyantlari ignore edilir.

# Docker volume verileri (eger lokal bind mount kullaniyorsan)
# Bizim setup'ta named volume kullaniliyor, bu satirlar genellikle
# gereksiz - ama emin olmak icin:
docker-data/
docker_data/
