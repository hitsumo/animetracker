# Anime Tracker - .gitignore
# Yapi (1.0.x duzlestirme sonrasi): repo koku = meta dosyalar + uygulama
# DOGRUDAN kokte (files/ web kok, catalog_server/, changelogs/, docker,
# installer). Eski araya giren AnimeTracker/ katmani 1.0.x'te kaldirildi.

# ============================================================
# HASSAS KONFIGURASYON - asla commit etme
# ============================================================
# Asagidaki desenlerin cogu BASENAME (egik cizgi yok) -> her derinlikte
# yakalanir. Yol/klasor yapisi degisse bile korumaya devam eder (0.6.4.x
# dersi). *_example.php sablonlari farkli basename oldugu icin ETKILENMEZ;
# repo'da kalir.

# Uygulama konfigi (DB sifreleri) - files/config.php
config.php

# Admin arac dosyalari - example versiyonlari repo'da
# admin_sync.php: hedef sunucu URL'i; admin_secret.php: HMAC anahtari
admin_sync.php
admin_secret.php

# Katalog sunucusu (catalog_server/) gizli configleri
admin_push_config.php
anime_api_config.php

# catalog_server/private/ - tum gercek configler + runtime (rate_limit/);
# yalniz *_example.php sablonlari commit edilir.
catalog_server/private/*
!catalog_server/private/*_example.php

# ============================================================
# RUNTIME / KULLANICI VERISI
# ============================================================

# Kullanici yukledigi kapak gorselleri (.htaccess haric)
files/uploads/*
!files/uploads/.htaccess

# Runtime cache ve gecici dosyalar (uygulama + katalog sunucusu)
files/temp/
catalog_cache.json
catalog_cache.json.tmp

# ============================================================
# DOCKER SECRETS
# ============================================================

# Ortam degiskenleri (gercek sifreler)
# NOT: .env.example commit edilir (ornek dosya, gercek sifre icermez)
.env
.env.local
.env.*.local

# Docker volume verileri (named volume kullaniyoruz; bind mount kalintilari)
docker-data/
docker_data/

# ============================================================
# BUILD CIKTILARI
# ============================================================

AnimeTracker.exe
*.zip

# XAMPP installer (150 MB - repoya koyma, release sayfasinda dagit)
xampp-*.exe

# NSIS build artiklari
*.nsi.bak

# ============================================================
# KISISEL GELISTIRME NOTLARI
# Build/release disiplinine gore ZIP'e GIRMEZ ve repo'ya da GITMEZ
# (kisisel notlar, ic dokumantasyon)
# ============================================================

PROJE_DURUMU.md
proje_durumu_*.md
KARARLAR*.md
notes_*.md
build_release_disiplini.md
FAZ*.md
*_TASARIMI.md
*_PLANI.md
i18n_durumu.md
xammp_*_dizin_listesi.txt
*_dizin_listesi.txt
*_dizin_yapisi.txt
dizin_listesi.txt
dizin_yapisi.txt

# ============================================================
# GELISTIRME ARTIKLARI / TEST
# ============================================================

session_test.php
csrf_test.php
test.php
files/test*.php

# Screenshot/img - repodaki gercek asset'leri istisna et
*.JPG
*.jpg
*.png
!files/img/*.jpg
!files/img/*.png
!anime-tracker-icon.ico
!screenshots/*.png
!screenshots/*.jpg

# ============================================================
# EDITOR / OS ARTIKLARI
# ============================================================

.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
.DS_Store
desktop.ini

# ============================================================
# LOG VE YEDEKLER
# ============================================================

*.log
error_log
*.bak
*.backup
*_backup.sql
